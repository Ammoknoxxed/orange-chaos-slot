<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CHAOS ORANGE | Login</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #050a0f 0%, #1a0800 100%);
            font-family: 'Inter', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: #fff;
        }

        .login-container {
            background: rgba(11, 19, 26, 0.95);
            border: 2px solid rgba(255, 85, 0, 0.2);
            border-radius: 20px;
            padding: 60px 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 0 50px rgba(255, 85, 0, 0.1);
            backdrop-filter: blur(10px);
        }

        .logo {
            text-align: center;
            margin-bottom: 40px;
            font-size: 48px;
        }

        h1 {
            text-align: center;
            font-size: 28px;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #ff5500, #ffcc00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            text-align: center;
            color: #8a9ba8;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            color: #8a9ba8;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            transition: 0.3s;
        }

        input:focus {
            outline: none;
            border-color: #ff5500;
            background: rgba(255, 85, 0, 0.05);
            box-shadow: 0 0 15px rgba(255, 85, 0, 0.2);
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #00e701, #00b300);
            border: none;
            border-radius: 8px;
            color: #000;
            font-weight: 900;
            font-size: 16px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: 0.3s;
            box-shadow: 0 0 20px rgba(0, 231, 1, 0.4);
            margin-top: 10px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(0, 231, 1, 0.6);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login:disabled {
            background: #333;
            color: #666;
            cursor: not-allowed;
            box-shadow: none;
        }

        .error {
            background: rgba(255, 0, 0, 0.1);
            border: 1px solid rgba(255, 0, 0, 0.3);
            color: #ff6b6b;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
            font-size: 14px;
        }

        .error.show {
            display: block;
        }

        .info {
            background: rgba(0, 231, 1, 0.05);
            border: 1px solid rgba(0, 231, 1, 0.2);
            color: #00e701;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 13px;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo">🍊</div>
        <h1>CHAOS ORANGE</h1>
        <p class="subtitle">Cascade Slot Machine</p>

        <div class="info">
            💰 Start with <strong>1000€</strong> balance<br>
            🎰 Play cascading slots with bombs & free spins<br>
            🏆 Compete on the leaderboard
        </div>

        <div class="error" id="error-msg"></div>

        <form id="login-form">
            <div class="form-group">
                <label for="username">Username</label>
                <input 
                    type="text" 
                    id="username" 
                    name="username" 
                    placeholder="Enter your username"
                    required
                    minlength="3"
                    maxlength="20"
                >
            </div>
            <button type="submit" class="btn-login" id="login-btn">Play Now</button>
        </form>
    </div>

    <script>
        const form = document.getElementById('login-form');
        const errorMsg = document.getElementById('error-msg');
        const loginBtn = document.getElementById('login-btn');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorMsg.classList.remove('show');

            const username = document.getElementById('username').value.trim();
            if (!username) {
                showError('Username required');
                return;
            }

            loginBtn.disabled = true;
            loginBtn.innerText = 'Loading...';

            try {
                const res = await fetch('/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username })
                });

                const data = await res.json();

                if (data.error) {
                    showError(data.error);
                    loginBtn.disabled = false;
                    loginBtn.innerText = 'Play Now';
                    return;
                }

                window.location.href = data.redirect;
            } catch (e) {
                showError('Connection error. Try again.');
                loginBtn.disabled = false;
                loginBtn.innerText = 'Play Now';
            }
        });

        function showError(msg) {
            errorMsg.innerText = msg;
            errorMsg.classList.add('show');
        }
    </script>
</body>
</html>
