<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net;">
    <title>Chaos Orange | The Juicer (High-End Edition)</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser-arcade-physics.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Russo+One&display=swap');

        body {
            background-color: #050505;
            color: #fff;
            font-family: 'Russo One', sans-serif;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            background: radial-gradient(circle at 50% 40%, #2a1100 0%, #050505 70%);
        }

        #game-container {
            position: relative;
            width: 1000px; /* Die Spielauflösung */
            height: 700px;
            box-shadow: 0 0 50px rgba(255, 102, 0, 0.3);
            border: 3px solid #333;
            border-radius: 10px;
            overflow: hidden;
        }

        /* Wir malen HTML-Texte (Balance, etc.) über das Spiel-Canvas */
        .overlay-text {
            position: absolute;
            pointer-events: none; /* Text blockiert keine Klicks */
            z-index: 100;
        }

        .balance-box {
            top: 20px;
            right: 20px;
            background: rgba(0,0,0,0.8);
            padding: 10px 20px;
            border: 1px solid #ff8c00;
            border-radius: 5px;
            font-size: 1.5rem;
            color: #0f0;
            text-shadow: 0 0 10px #0f0;
        }

        .msg-board {
            bottom: 120px;
            width: 100%;
            text-align: center;
            font-size: 2rem;
            color: #ff8c00;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px #ff8c00, 0 0 3px #fff;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <div class="overlay-text balance-box">
            BALANCE: <span id="balance-amount"><%= user.balance.toFixed(2) %></span> €
        </div>
        <div class="overlay-text msg-board" id="msg-board">WAITING FOR SPIN...</div>
    </div>

    <script>
        console.log("Starting Chaos Orange | High-End Phaser V1");

        const msgBoard = document.getElementById('msg-board');
        const balanceDisplay = document.getElementById('balance-amount');

        // ==========================================
        // CONFIGURATION
        // ==========================================
        const REEL_COUNT = 5;
        const ROW_COUNT = 5;
        const SYMBOL_SIZE = 100; // Pixelgröße pro Symbol-Grafik (High-End braucht 100x100)
        const REEL_OFFSET_X = 250; // Startposition links
        const REEL_OFFSET_Y = 100; // Startposition oben
        const SPIN_SPEED = 12; // Wie viele Symbole pro Sekunde rasen

        // Backend Symbole zu Phaser Asset-Namen mappen
        const symbolMap = {
            'ORANGE': 'orange', 'ROLEX': 'rolex', 'BÜNDEL': 'bundel', 'ENERGY': 'energy', 'CAP': 'cap',
            'ACE': 'ace', 'KING': 'king', 'QUEEN': 'queen', 'JACK': 'jack', 'TEN': 'ten',
            'JUICER': 'juicer', 'SCATTER': 'scatter'
        };
        const allSymbols = Object.values(symbolMap);


        // ==========================================
        // PHASER 3 ENGINE
        // ==========================================

        // --- PRELOAD SCENE (Hier laden wir die epischen Grafiken!) ---
        class PreloadScene extends Phaser.Scene {
            constructor() { super('PreloadScene'); }

            preload() {
                // Ladebalken
                let loadingText = this.add.text(500, 350, 'LOADING CASINO ASSETS...', { 
                    fontFamily: 'Russo One', fontSize: '24px', color: '#ff8c00'
                }).setOrigin(0.5);

                // --- HIER MUSST DU DEINE BILDER ANLEGEN ---
                // Für den Start (damit es nicht abstürzt) malen wir DUMMY-Kugeln.
                this.load.setBaseURL('https://labs.phaser.io/assets/'); // Nur für die Dummies!

                // Placeholder Grafiken (Wir nehmen bunte Kreise)
                allSymbols.forEach(symKey => {
                    this.load.image(`sym_${symKey}`, `sprites/aqua_ball.png`); // DUMMY!
                });

                // Hintergrund-Grafik
                this.load.image('game_bg', 'skies/darkstone.png'); // DUMMY!
                // Spin Button Grafik (Wichtig für epische Optik)
                this.load.image('btn_spin', 'sprites/button_normal.png'); // DUMMY!
                this.load.image('btn_spin_p', 'sprites/button_pressed.png'); // DUMMY!
            }

            create() { this.scene.start('GameScene'); }
        }

        // --- MAIN GAME SCENE (Die Slot-Mechanik) ---
        class GameScene extends Phaser.Scene {
            constructor() { super('GameScene'); }

            create() {
                // 1. Hintergrund (Massiver High-End-Glow)
                this.add.image(500, 350, 'game_bg').setAlpha(0.5);

                // 2. Walzen Gehäuse (Container)
                this.reelsContainer = this.add.container(REEL_OFFSET_X, REEL_OFFSET_Y);
                this.reels = [];

                // Walzen-Struktur aufbauen
                for (let col = 0; col < REEL_COUNT; col++) {
                    const reelData = {
                        container: this.add.container(col * (SYMBOL_SIZE + 10), 0),
                        symbols: [],
                        isSpinning: false,
                        finalResult: [] // Speichert das Backend Ergebnis
                    };
                    this.reelsContainer.add(reelData.container);
                    
                    // Jede Walze braucht 2 Extra-Symbole für den Loop-Effekt (7 statt 5)
                    for (let r = -1; r < ROW_COUNT + 1; r++) {
                        let sym = this.add.image(SYMBOL_SIZE / 2, r * SYMBOL_SIZE + (SYMBOL_SIZE / 2), 'sym_orange')
                            .setDisplaySize(SYMBOL_SIZE, SYMBOL_SIZE);
                        reelData.container.add(sym);
                        reelData.symbols.push(sym);
                    }
                    // Walzen-Maske (Damit Symbole oben/unten unsichtbar sind)
                    const mask = this.add.graphics().fillRect(
                        REEL_OFFSET_X + col * (SYMBOL_SIZE + 10), REEL_OFFSET_Y, 
                        SYMBOL_SIZE, ROW_COUNT * SYMBOL_SIZE
                    ).createGeometryMask();
                    reelData.container.setMask(mask);
                    this.reels.push(reelData);
                }

                // Initial Randomizer (Wirft zufällige Dummies ins Grid)
                this.reels.forEach(reel => {
                    reel.symbols.forEach(sym => sym.setTexture(`sym_${Phaser.Utils.Array.GetRandom(allSymbols)}`));
                });

                // 3. UI: Spin Button (High-End Interactive Image)
                this.spinBtn = this.add.image(850, 600, 'btn_spin').setInteractive({ useHandCursor: true });
                this.spinBtn.on('pointerdown', () => { this.spinBtn.setTexture('btn_spin_p'); this.startSpin(); });
                this.spinBtn.on('pointerup', () => { this.spinBtn.setTexture('btn_spin'); });

                this.add.text(850, 600, 'SPIN', { fontFamily: 'Russo One', fontSize: '32px' }).setOrigin(0.5).setPadding(2);
                
                // Status Variablen
                this.isGameRunning = false;
            }

            // --- SPIEL LOOP (Hier wird die Walze bewegt) ---
            update(time, delta) {
                if (this.reels[0].isSpinning) {
                    this.reels.forEach(reel => {
                        // Walze nach unten bewegen
                        reel.symbols.forEach(sym => {
                            sym.y += SPIN_SPEED;
                            
                            // LOOP EFFEKT: Wenn Symbol unten rausfliegt, oben wieder rein
                            if (sym.y >= (ROW_COUNT + 1) * SYMBOL_SIZE) {
                                sym.y -= (ROW_COUNT + 2) * SYMBOL_SIZE;
                                
                                // Solange wir auf das Server-Ergebnis warten, würfeln wir zufällige Dummy-Symbole
                                if (!reel.finalResult.length) {
                                    sym.setTexture(`sym_${Phaser.Utils.Array.GetRandom(allSymbols)}`);
                                } else {
                                    // WICHTIG: Hier kommt die Magie! Wir füllen die echten Ergebnisse von oben ein.
                                    // Diese Logik ist komplex, lassen wir für V1 mal raus.
                                }
                            }
                        });
                    });
                }
            }

            // --- SPIN STARTEN ---
            async startSpin() {
                if (this.isGameRunning) return;
                this.isGameRunning = true;
                this.spinBtn.setAlpha(0.5); // Button deaktivieren
                
                msgBoard.innerText = "SPINNING...";
                msgBoard.style.color = "#fff";

                // 1. Walzen fangen an, butterweich durchzudrehen
                this.reels.forEach(reel => { reel.isSpinning = true; reel.finalResult = []; });

                try {
                    // 2. Server nach dem Ergebnis fragen
                    const response = await fetch('/api/spin', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                    const result = await response.json();

                    if (result.error) { msgBoard.innerText = result.error; this.resetSpin(); return; }

                    balanceDisplay.innerText = result.newBalance.toFixed(2);

                    // 3. Walzen mit dem ECHTEN Ergebnis stoppen (HACKSAW STYLE!)
                    for (let c = 0; c < REEL_COUNT; c++) {
                        // Wir bauen die Spannung auf (Links stoppt zuerst)
                        await new Promise(res => setTimeout(res, 300)); 
                        
                        this.stopReel(c, result.grid);
                    }

                    // 4. Gewinn-Auswertung
                    await this.handleWinAnimations(result);

                } catch (err) { console.error(err); this.resetSpin(); }
            }

            // --- WALZE STOPPEN (Nacheinander mit Nachfeder-Effekt) ---
            stopReel(colIdx, gridData) {
                const reel = this.reels[colIdx];
                reel.isSpinning = false; // update() Loop für diese Walze stoppen
                
                // Wir malen die echten Symbole des Backend-Grids sofort in die Walze
                for(let r=0; r<ROW_COUNT; r++) {
                    const symData = gridData[r][colIdx];
                    const sprite = reel.symbols.find(s => {
                        // Wir suchen das Symbol, das gerade visuell am nahesten an der Reihe r ist
                        return Math.abs(s.y - (r * SYMBOL_SIZE + (SYMBOL_SIZE/2))) < 50;
                    });
                    
                    if(sprite) {
                        sprite.setTexture(`sym_${symbolMap[symData.name]}`);
                        // Butterweicher Nachfeder-Effekt (Easing)
                        this.tweens.add({
                            targets: sprite,
                            y: r * SYMBOL_SIZE + (SYMBOL_SIZE/2),
                            duration: 150,
                            ease: 'Back.easeOut' // Das macht den Hacksaw-Style Bounce!
                        });
                    }
                }
            }

            // --- GEWINN-ESKALATION (Partikel, multi, etc.) ---
            async handleWinAnimations(result) {
                // Wenn Juicer Duelle passiert sind (Hardcore Shake & Glow!)
                if (result.juicerDuels && result.juicerDuels.length > 0) {
                    for (let duel of result.juicerDuels) {
                        msgBoard.innerText = `VS DUEL...`;
                        
                        // Hier müssten wir jetzt Partikeleffekte in Phaser zünden!
                        this.reels[duel.col].symbols.forEach(sym => {
                            sym.setTint(0xff8c00); // Dummy-Glow Effekt
                        });
                        
                        // Bildschirm wackeln (Screen Shake)
                        this.cameras.main.shake(500, 0.01);
                        await new Promise(res => setTimeout(res, 800)); 
                        
                        msgBoard.innerText = `🔥 ${duel.multi}x JUICER! 🔥`;
                        await new Promise(res => setTimeout(res, 1200));
                        
                        this.reels[duel.col].symbols.forEach(sym => sym.clearTint());
                    }
                }

                if (result.win > 0) {
                    msgBoard.innerText = `🏆 BIG WIN: ${result.win.toFixed(2)} €!`;
                    balanceDisplay.innerText = result.newBalance.toFixed(2); 
                } else {
                    msgBoard.innerText = "DEAD SPIN";
                }

                this.resetSpin();
            }

            resetSpin() { this.isGameRunning = false; this.spinBtn.setAlpha(1); }
        }

        // ==========================================
        // MAIN PHASER CONFIG
        // ==========================================
        const config = {
            type: Phaser.AUTO,
            width: 1000,
            height: 700,
            parent: 'game-container',
            transparent: true, // Damit der HTML Hintergrund durchscheint
            scene: [PreloadScene, GameScene]
        };
        const game = new Phaser.Game(config);

    </script>
</body>
</html>
