<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net;">
    <title>Chaos Orange | Prototype</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser-arcade-physics.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Russo+One&display=swap');

        body {
            background-color: #050505;
            color: #fff;
            font-family: 'Russo One', sans-serif;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            background: radial-gradient(circle at 50% 40%, #1a0a00 0%, #000 80%);
        }

        #game-container {
            position: relative;
            width: 900px; 
            height: 700px;
            box-shadow: 0 0 40px rgba(255, 102, 0, 0.2);
            border: 2px solid #333;
            border-radius: 15px;
            overflow: hidden;
        }

        .overlay-text { position: absolute; pointer-events: none; z-index: 100; }

        .balance-box {
            top: 20px;
            right: 20px;
            background: rgba(10,10,10,0.9);
            padding: 10px 20px;
            border: 1px solid #ff8c00;
            border-radius: 8px;
            font-size: 1.5rem;
            box-shadow: 0 0 15px rgba(255, 140, 0, 0.3);
        }

        #msg-board {
            bottom: 30px;
            width: 100%;
            text-align: center;
            font-size: 2.2rem;
            color: #ff8c00;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 15px rgba(255, 140, 0, 0.8), 0 0 5px #fff;
            transition: all 0.3s ease;
        }

        #spin-btn-html {
            position: absolute;
            bottom: 90px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(180deg, #ff8c00, #cc3300);
            border: 2px solid #ffb366;
            color: white;
            font-family: 'Russo One', sans-serif;
            font-size: 2rem;
            padding: 10px 50px;
            border-radius: 40px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(204, 51, 0, 0.5);
            z-index: 101;
        }
        #spin-btn-html:active { transform: translateX(-50%) translateY(5px); }
        #spin-btn-html:disabled { background: #333; color: #666; border-color: #444; cursor: not-allowed; transform: translateX(-50%); }
    </style>
</head>
<body>

    <div id="game-container">
        <div class="overlay-text balance-box">
            <span style="color:#aaa;">USER:</span> <%= user.username %> | <span style="color:#0f0;" id="balance-amount"><%= user.balance.toFixed(2) %></span> €
        </div>
        <div class="overlay-text" id="msg-board">PRESS SPIN</div>
        <button id="spin-btn-html">SPIN (1€)</button>
    </div>

    <script>
        const msgBoard = document.getElementById('msg-board');
        const balanceDisplay = document.getElementById('balance-amount');
        const htmlSpinBtn = document.getElementById('spin-btn-html');

        const REEL_COUNT = 5;
        const ROW_COUNT = 5;
        const SYMBOL_SIZE = 110; 
        const REEL_OFFSET_X = 175; 
        const REEL_OFFSET_Y = 100; 

        // FARBEN & TEXTE ANSTATT BILDER/EMOJIS (100% Sicher für jeden Browser)
        const symbolStyles = {
            'ORANGE':  { text: 'ORG', color: 0xff6600, textColor: '#ffffff' },
            'ROLEX':   { text: 'RLX', color: 0xffcc00, textColor: '#000000' },
            'BÜNDEL':  { text: 'CASH', color: 0x00cc44, textColor: '#ffffff' },
            'ENERGY':  { text: 'NRG', color: 0x0088ff, textColor: '#ffffff' },
            'CAP':     { text: 'CAP', color: 0x555555, textColor: '#ffffff' },
            'ACE':     { text: 'A', color: 0x222222, textColor: '#ffffff' },
            'KING':    { text: 'K', color: 0x222222, textColor: '#ffffff' },
            'QUEEN':   { text: 'Q', color: 0x222222, textColor: '#ffffff' },
            'JACK':    { text: 'J', color: 0x222222, textColor: '#ffffff' },
            'TEN':     { text: '10', color: 0x222222, textColor: '#ffffff' },
            'JUICER':  { text: 'VS', color: 0x9900ff, textColor: '#ffffff' }, // Violetter VS Juicer
            'SCATTER': { text: 'BONUS', color: 0xffdd00, textColor: '#000000' } // Gelber Scatter
        };
        const symbolKeys = Object.keys(symbolStyles);

        let freeSpinsLeft = 0;
        let totalBonusWin = 0;

        class GameScene extends Phaser.Scene {
            constructor() { super('GameScene'); }

            create() {
                // Roter Freispiel Hintergrund
                this.bonusBg = this.add.rectangle(450, 350, 900, 700, 0x880000).setAlpha(0);
                
                // Hintergrund Slot Raster
                this.add.rectangle(450, 375, 560, 560, 0x111111).setStrokeStyle(4, 0x333333);

                this.reelsContainer = this.add.container(REEL_OFFSET_X, REEL_OFFSET_Y);
                this.reels = [];

                const globalMask = this.add.graphics()
                    .fillRect(REEL_OFFSET_X, REEL_OFFSET_Y, SYMBOL_SIZE * REEL_COUNT, SYMBOL_SIZE * ROW_COUNT)
                    .createGeometryMask();
                this.reelsContainer.setMask(globalMask);

                for (let col = 0; col < REEL_COUNT; col++) {
                    const reelData = {
                        container: this.add.container(col * SYMBOL_SIZE, 0),
                        symbols: [],
                        isSpinning: false,
                        finalResult: null
                    };
                    this.reelsContainer.add(reelData.container);
                    
                    for (let r = -1; r < ROW_COUNT + 1; r++) {
                        // REINE FORMEN STATT EMOJIS!
                        let bg = this.add.rectangle(SYMBOL_SIZE / 2, r * SYMBOL_SIZE + (SYMBOL_SIZE / 2), SYMBOL_SIZE - 8, SYMBOL_SIZE - 8, 0x222222).setStrokeStyle(2, 0x000000).setOrigin(0.5);
                        let symTxt = this.add.text(SYMBOL_SIZE / 2, r * SYMBOL_SIZE + (SYMBOL_SIZE / 2), 'A', { 
                            fontFamily: 'Arial', fontSize: '30px', fontStyle: 'bold', color: '#ffffff'
                        }).setOrigin(0.5);
                        
                        reelData.container.add(bg);
                        reelData.container.add(symTxt);
                        reelData.symbols.push({ textObj: symTxt, bgObj: bg, yPos: r });
                    }
                    this.reels.push(reelData);
                }

                // Initial füllen
                this.reels.forEach(reel => {
                    reel.symbols.forEach(s => this.setSymbolVisual(s, Phaser.Utils.Array.GetRandom(symbolKeys)));
                });

                htmlSpinBtn.addEventListener('click', () => this.startSpin());
            }

            // Hilfsfunktion zum Stylen der Placeholder-Blöcke
            setSymbolVisual(symbolObj, symName) {
                const style = symbolStyles[symName];
                symbolObj.bgObj.setFillStyle(style.color);
                symbolObj.textObj.setText(style.text);
                symbolObj.textObj.setColor(style.textColor);
            }

            update() {
                this.reels.forEach(reel => {
                    if (reel.isSpinning) {
                        reel.symbols.forEach(s => {
                            s.textObj.y += 35; // Schnellerer Spin!
                            s.bgObj.y += 35;
                            
                            if (s.textObj.y > (ROW_COUNT) * SYMBOL_SIZE + (SYMBOL_SIZE/2)) {
                                s.textObj.y -= (ROW_COUNT + 2) * SYMBOL_SIZE;
                                s.bgObj.y -= (ROW_COUNT + 2) * SYMBOL_SIZE;
                                this.setSymbolVisual(s, Phaser.Utils.Array.GetRandom(symbolKeys));
                            }
                        });
                    }
                });
            }

            async startSpin() {
                htmlSpinBtn.disabled = true;
                const isAutoFreeSpin = freeSpinsLeft > 0;

                if (isAutoFreeSpin) {
                    msgBoard.innerText = `FREESPINS LEFT: ${freeSpinsLeft}`;
                    msgBoard.style.color = "#ffdd00";
                } else {
                    msgBoard.innerText = "SPINNING...";
                    msgBoard.style.color = "#fff";
                    totalBonusWin = 0; 
                    this.tweens.add({ targets: this.bonusBg, alpha: 0, duration: 300 });
                }

                this.reels.forEach(reel => { reel.isSpinning = true; });

                try {
                    const response = await fetch('/api/spin', { 
                        method: 'POST', 
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ isFreeSpin: isAutoFreeSpin })
                    });
                    const result = await response.json();

                    if (result.error) { msgBoard.innerText = result.error; htmlSpinBtn.disabled = false; return; }
                    balanceDisplay.innerText = result.newBalance.toFixed(2);

                    for (let c = 0; c < REEL_COUNT; c++) {
                        await new Promise(res => setTimeout(res, 200)); 
                        this.stopReel(c, result.grid);
                    }

                    await this.handleWinAnimations(result, isAutoFreeSpin);

                } catch (err) { console.error(err); htmlSpinBtn.disabled = false; }
            }

            stopReel(colIdx, gridData) {
                const reel = this.reels[colIdx];
                reel.isSpinning = false; 
                
                for(let r=0; r<ROW_COUNT; r++) {
                    const symName = gridData[r][colIdx].name;
                    const s = reel.symbols.sort((a,b) => a.textObj.y - b.textObj.y)[r+1]; 
                    
                    this.setSymbolVisual(s, symName);
                    
                    let targetY = r * SYMBOL_SIZE + (SYMBOL_SIZE/2);
                    s.textObj.y = targetY - 40;
                    s.bgObj.y = targetY - 40;
                    
                    // Wuchtiger Bounce-Effekt beim Landen
                    this.tweens.add({ targets: [s.textObj, s.bgObj], y: targetY, duration: 400, ease: 'Back.easeOut' });
                }
            }

            async handleWinAnimations(result, wasFreeSpin) {
                // 1. SCATTER TRIGGER ANIMATION
                if (!wasFreeSpin && result.scatters >= 3) {
                    msgBoard.innerText = "🚨 THE BIG SQUEEZE 🚨";
                    msgBoard.style.color = "#ff0000";
                    msgBoard.style.transform = "scale(1.4)";
                    
                    // Roter Pulseffekt im Hintergrund
                    this.tweens.add({ targets: this.bonusBg, alpha: 0.5, yoyo: true, repeat: -1, duration: 400 });
                    this.cameras.main.shake(1500, 0.02); // Massiver Screen Shake
                    
                    await new Promise(res => setTimeout(res, 3000));
                    msgBoard.style.transform = "scale(1)";
                    freeSpinsLeft = 10; 
                }

                // 2. VS JUICER AUSKLAPPEN ANIMATION
                if (result.juicerDuels && result.juicerDuels.length > 0) {
                    for (let duel of result.juicerDuels) {
                        msgBoard.innerText = `VS DUEL...`;
                        msgBoard.style.color = "#ff8c00";
                        
                        // Die GANZE Spalte wird zu einem fetten Juicer
                        this.reels[duel.col].symbols.forEach(s => {
                            if (s.yPos >= 0 && s.yPos < 5) { 
                                s.bgObj.setFillStyle(0xff0000); // Lava Rot
                                s.textObj.setText(`VS\n${duel.multi}x`);
                                s.textObj.setColor('#ffffff');
                                s.textObj.setFontSize('26px');
                            }
                        });
                        
                        this.cameras.main.shake(500, 0.01);
                        await new Promise(res => setTimeout(res, 1000)); 
                        
                        msgBoard.innerText = `🔥 ${duel.multi}x JUICER 🔥`;
                        msgBoard.style.color = "#ffdd00";
                        msgBoard.style.transform = "scale(1.3)";
                        await new Promise(res => setTimeout(res, 1200));
                        msgBoard.style.transform = "scale(1)";
                    }
                }

                // 3. GEWINN ANZEIGE
                if (result.win > 0) {
                    if (wasFreeSpin) totalBonusWin += result.win;
                    msgBoard.innerText = `WIN: ${result.win.toFixed(2)} €!`;
                    msgBoard.style.color = "#00ff44";
                    
                    // Gewinn wackelt leicht
                    this.tweens.add({ targets: msgBoard, scale: 1.1, yoyo: true, duration: 200 });
                    await new Promise(res => setTimeout(res, 1200));
                } else if (!wasFreeSpin && result.scatters < 3) {
                    msgBoard.innerText = "DEAD SPIN";
                    msgBoard.style.color = "#555";
                }

                // 4. FREISPIEL LOOP LOGIK
                if (freeSpinsLeft > 0) {
                    freeSpinsLeft--;
                    await new Promise(res => setTimeout(res, 1000));
                    
                    if (freeSpinsLeft === 0) {
                        msgBoard.innerText = `🏆 TOTAL BONUS WIN: ${totalBonusWin.toFixed(2)} € 🏆`;
                        msgBoard.style.color = "#00ff44";
                        msgBoard.style.transform = "scale(1.2)";
                        this.tweens.add({ targets: this.bonusBg, alpha: 0, duration: 1000 }); 
                        await new Promise(res => setTimeout(res, 4000));
                        msgBoard.style.transform = "scale(1)";
                        msgBoard.innerText = "PRESS SPIN";
                        htmlSpinBtn.disabled = false;
                    } else {
                        this.startSpin(); 
                    }
                } else {
                    htmlSpinBtn.disabled = false;
                }
            }
        }

        // Wir erzwingen CANVAS, damit es bei jedem Browser (auch Brave) läuft!
        const config = { type: Phaser.CANVAS, width: 900, height: 700, parent: 'game-container', transparent: true, scene: [GameScene] };
        const game = new Phaser.Game(config);
    </script>
</body>
</html>
