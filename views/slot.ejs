<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval';">
    <title>Chaos Orange | The Juicer Slot</title>
    <link href="https://fonts.googleapis.com/css2?family=Russo+One&display=swap" rel="stylesheet">
    
    <style>
        body {
            background-color: #050505;
            color: #fff;
            font-family: 'Russo One', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            overflow: hidden;
            /* Blut-Orangen Hintergrund-Glow */
            background: radial-gradient(circle at 50% 40%, #2a1100 0%, #050505 70%);
        }

        /* Top Bar: Kontostand */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 90%;
            max-width: 650px;
            margin-bottom: 25px;
            padding: 15px 25px;
            background: rgba(20, 20, 20, 0.8);
            border: 1px solid #ff6600;
            border-radius: 12px;
            font-size: 1.4rem;
            box-sizing: border-box;
            box-shadow: 0 0 20px rgba(255, 102, 0, 0.15), inset 0 0 10px rgba(0,0,0,0.8);
            backdrop-filter: blur(10px);
        }
        .balance-text { color: #888; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 1px; }
        .balance-amount { color: #00ff44; font-size: 1.8rem; text-shadow: 0 0 15px rgba(0, 255, 68, 0.5); }
        .juicer-name { color: #fff; text-transform: uppercase; text-shadow: 0 0 10px rgba(255,255,255,0.3); }

        /* Das Slot Gehäuse - Massiv und düster */
        .slot-machine {
            background: linear-gradient(145deg, #111, #080808);
            padding: 15px;
            border-radius: 18px;
            border: 2px solid #333;
            box-shadow: 0 30px 60px rgba(0,0,0,0.9), 0 0 40px rgba(255, 102, 0, 0.1), inset 0 0 30px rgba(0,0,0,1);
            position: relative;
        }

        /* 5x5 Raster */
        .grid {
            display: grid;
            grid-template-columns: repeat(5, 80px);
            grid-template-rows: repeat(5, 80px);
            gap: 8px;
            background-color: #030303;
            padding: 10px;
            border-radius: 12px;
            border: 1px solid #1a1a1a;
            box-shadow: inset 0 10px 20px rgba(0,0,0,0.8);
        }

        /* Die Symbole */
        .cell {
            background: linear-gradient(180deg, #1f1f1f 0%, #121212 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            position: relative;
            overflow: hidden;
            border-bottom: 3px solid #0a0a0a;
            border-top: 1px solid #2a2a2a;
            box-shadow: 0 5px 10px rgba(0,0,0,0.5);
            transition: transform 0.1s;
        }

        /* Walzen Motion-Blur Effekt (Fake Spinning) */
        .spinning {
            animation: verticalShake 0.1s infinite linear;
            filter: blur(2px) brightness(1.2);
            opacity: 0.8;
        }
        @keyframes verticalShake {
            0% { transform: translateY(-5px); }
            50% { transform: translateY(5px); }
            100% { transform: translateY(-5px); }
        }

        /* JUICER AUSKLAPPEN: Lava-Effekt */
        .juicer-active {
            background: linear-gradient(180deg, #ff8c00 0%, #ff0000 100%) !important;
            box-shadow: 0 0 30px #ff4500, inset 0 0 20px #000 !important;
            border-color: #fff;
            color: #fff;
            animation: hardcoreShake 0.3s infinite alternate, glowPulse 0.5s infinite alternate;
            z-index: 10;
        }
        @keyframes glowPulse {
            0% { filter: brightness(1); }
            100% { filter: brightness(1.5); }
        }
        @keyframes hardcoreShake {
            0% { transform: translate(1px, 2px) scale(1.05); }
            50% { transform: translate(-2px, -1px) scale(1.05); }
            100% { transform: translate(2px, 1px) scale(1.05); }
        }

        /* Controls Bereich */
        .controls {
            margin-top: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        
        #msg-board {
            font-size: 2rem;
            color: #ff6600;
            height: 40px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 0 0 20px rgba(255, 102, 0, 0.8), 0 0 5px #fff;
            transition: all 0.3s;
        }

        .spin-btn {
            background: linear-gradient(180deg, #ff8c00 0%, #cc3300 100%);
            color: #fff;
            font-family: 'Russo One', sans-serif;
            font-size: 2.5rem;
            letter-spacing: 2px;
            padding: 15px 80px;
            border: 2px solid #ffb366;
            border-radius: 50px;
            cursor: pointer;
            text-transform: uppercase;
            box-shadow: 0 15px 30px rgba(204, 51, 0, 0.5), inset 0 5px 10px rgba(255,255,255,0.4);
            transition: all 0.1s;
        }
        .spin-btn:active {
            transform: translateY(8px);
            box-shadow: 0 5px 15px rgba(204, 51, 0, 0.5), inset 0 2px 5px rgba(255,255,255,0.4);
        }
        .spin-btn:disabled {
            background: #333;
            border-color: #555;
            color: #666;
            box-shadow: inset 0 5px 10px rgba(0,0,0,0.5);
            cursor: not-allowed;
            transform: none;
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <span><span class="balance-text">User: </span><span class="juicer-name"><%= user.username %></span></span>
        <span><span class="balance-text">Balance: </span><span class="balance-amount" id="balance-display"><%= user.balance.toFixed(2) %></span><span style="color:#00ff44; font-size:1.2rem;"> €</span></span>
    </div>

    <div class="slot-machine">
        <div class="grid" id="slot-grid"></div>
    </div>

    <div class="controls">
        <div id="msg-board">GRIND TO WIN</div>
        <button class="spin-btn" id="spin-btn">SPIN</button>
    </div>

    <script>
        console.log("Chaos Orange UI V2 loaded.");

        const gridElement = document.getElementById('slot-grid');
        const spinBtn = document.getElementById('spin-btn');
        const msgBoard = document.getElementById('msg-board');
        const balanceDisplay = document.getElementById('balance-display');
        
        let isSpinning = false;
        const cols = 5;
        const rows = 5;

        // Alle Symbole für die Fake-Rollen Animation
        const fakeSymbols = ['🍊', '⌚', '💵', '🥤', '🧢', 'A', 'K', 'Q', 'J', '10', '🌪️', '🌟'];
        let spinIntervals = []; // Speichert die Intervalle für jede Spalte

        function initGrid() {
            gridElement.innerHTML = '';
            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    let cell = document.createElement('div');
                    cell.className = 'cell';
                    cell.id = `cell-${r}-${c}`;
                    cell.innerText = fakeSymbols[Math.floor(Math.random() * fakeSymbols.length)]; 
                    gridElement.appendChild(cell);
                }
            }
        }
        initGrid();

        spinBtn.addEventListener('click', async function startSpin() {
            if (isSpinning) return;
            isSpinning = true;
            spinBtn.disabled = true;
            msgBoard.innerText = "SPINNING...";
            msgBoard.style.color = "#fff";
            msgBoard.style.transform = "scale(1)";

            // 1. Walzen fangen an, wie verrückt durchzudrehen!
            for (let c = 0; c < cols; c++) {
                for (let r = 0; r < rows; r++) {
                    let cell = document.getElementById(`cell-${r}-${c}`);
                    cell.classList.remove('juicer-active');
                    cell.classList.add('spinning');
                    
                    // Symbole wechseln in Millisekunden
                    let interval = setInterval(() => {
                        cell.innerText = fakeSymbols[Math.floor(Math.random() * fakeSymbols.length)];
                    }, 40); 
                    spinIntervals.push({ row: r, col: c, interval: interval });
                }
            }

            try {
                // 2. Server nach dem Ergebnis fragen
                const response = await fetch('/api/spin', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const result = await response.json();

                if (result.error) {
                    msgBoard.innerText = result.error;
                    msgBoard.style.color = "#ff0000";
                    stopAllIntervals();
                    isSpinning = false;
                    spinBtn.disabled = false;
                    return;
                }

                balanceDisplay.innerText = result.newBalance.toFixed(2);

                // 3. Walzen mit dem ECHTEN Ergebnis stoppen (Nacheinander, wie Hacksaw!)
                for (let c = 0; c < cols; c++) {
                    // Die Spannung steigt von links nach rechts
                    await new Promise(res => setTimeout(res, 250)); 
                    
                    for (let r = 0; r < rows; r++) {
                        let cellData = spinIntervals.find(i => i.row === r && i.col === c);
                        clearInterval(cellData.interval); // Fake-Rolle stoppen
                        
                        let cell = document.getElementById(`cell-${r}-${c}`);
                        cell.classList.remove('spinning');
                        cell.innerText = result.grid[r][c].icon; // Echtes Symbol einsetzen
                    }
                }

                spinIntervals = []; // Liste leeren
                await handleWinAnimations(result);

            } catch (err) {
                console.error("SERVER ERROR:", err);
                msgBoard.innerText = "CONNECTION LOST!";
                stopAllIntervals();
                isSpinning = false;
                spinBtn.disabled = false;
            }
        });

        function stopAllIntervals() {
            spinIntervals.forEach(item => clearInterval(item.interval));
            spinIntervals = [];
            document.querySelectorAll('.cell').forEach(c => c.classList.remove('spinning'));
        }

        async function handleWinAnimations(result) {
            if (result.scatters >= 3) {
                msgBoard.innerText = "🚨 THE BIG SQUEEZE 🚨";
                msgBoard.style.color = "#ff0000";
                msgBoard.style.transform = "scale(1.2)";
            }

            if (result.juicerDuels && result.juicerDuels.length > 0) {
                for (let duel of result.juicerDuels) {
                    for (let r = 0; r < rows; r++) {
                        let cell = document.getElementById(`cell-${r}-${duel.col}`);
                        cell.classList.add('juicer-active');
                        cell.innerText = '🌪️';
                    }
                    msgBoard.innerText = `VS DUEL...`;
                    msgBoard.style.color = "#ff8c00";
                    await new Promise(res => setTimeout(res, 1000)); 
                    
                    msgBoard.innerText = `🔥 ${duel.multi}x JUICER 🔥`;
                    msgBoard.style.color = "#ffdd00";
                    msgBoard.style.transform = "scale(1.3)";
                    await new Promise(res => setTimeout(res, 1200));
                    msgBoard.style.transform = "scale(1)";
                }
            }

            if (result.win > 0) {
                msgBoard.innerText = `BIG WIN: ${result.win.toFixed(2)} €!`;
                msgBoard.style.color = "#00ff44";
                msgBoard.style.transform = "scale(1.2)";
                balanceDisplay.innerText = result.newBalance.toFixed(2); 
            } else {
                if (result.scatters < 3) {
                    msgBoard.innerText = "DEAD SPIN";
                    msgBoard.style.color = "#555";
                    msgBoard.style.textShadow = "none";
                }
            }

            isSpinning = false;
            spinBtn.disabled = false;
        }
    </script>
</body>
</html>
