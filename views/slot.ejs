<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval';">
    <title>Chaos Orange | The Juicer Slot</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@700&display=swap');

        body {
            background-color: #0a0a0a;
            color: #fff;
            font-family: 'Roboto Mono', monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            overflow: hidden;
            background-image: radial-gradient(circle at center, #1a1000 0%, #000 100%);
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            width: 90%;
            max-width: 600px;
            margin-bottom: 20px;
            padding: 15px 20px;
            background: rgba(255, 140, 0, 0.1);
            border: 1px solid #ff8c00;
            border-radius: 10px;
            font-size: 1.2rem;
            box-sizing: border-box;
            box-shadow: 0 0 15px rgba(255, 140, 0, 0.2);
        }
        .balance-text { color: #aaa; }
        .balance-amount { color: #0f0; font-weight: bold; text-shadow: 0 0 5px #0f0; }

        .slot-machine {
            background: #111;
            padding: 10px;
            border-radius: 15px;
            border: 3px solid #333;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 0 20px rgba(0,0,0,1);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(5, 70px);
            grid-template-rows: repeat(5, 70px);
            gap: 5px;
            background-color: #050505;
            padding: 5px;
            border-radius: 10px;
        }

        .cell {
            background: #1a1a1a;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            position: relative;
            overflow: hidden;
            border: 1px solid #2a2a2a;
        }

        .spinning {
            animation: spinBlur 0.15s infinite linear;
            color: transparent;
            text-shadow: 0 0 15px rgba(255, 255, 255, 0.8);
        }
        @keyframes spinBlur {
            0% { transform: translateY(-10px); }
            50% { transform: translateY(10px); }
            100% { transform: translateY(-10px); }
        }

        .juicer-active {
            background-color: #ff8c00 !important;
            box-shadow: 0 0 20px #ff8c00, inset 0 0 10px #000 !important;
            border-color: #fff;
            animation: shake 0.4s infinite;
        }
        @keyframes shake {
            0% { transform: translate(1px, 1px) rotate(0deg); }
            25% { transform: translate(-1px, -2px) rotate(-1deg); }
            50% { transform: translate(-3px, 0px) rotate(1deg); }
            75% { transform: translate(3px, 2px) rotate(0deg); }
            100% { transform: translate(1px, -1px) rotate(0deg); }
        }

        .controls {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }
        
        .spin-btn {
            background: linear-gradient(135deg, #ff8c00, #ff4500);
            color: #fff;
            font-family: 'Roboto Mono', monospace;
            font-size: 2rem;
            font-weight: bold;
            padding: 15px 60px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            text-transform: uppercase;
            box-shadow: 0 10px 20px rgba(255, 69, 0, 0.4);
            transition: all 0.1s;
        }
        .spin-btn:active {
            transform: translateY(5px);
        }
        .spin-btn:disabled {
            background: #555;
            color: #888;
            cursor: not-allowed;
        }

        #msg-board {
            font-size: 1.5rem;
            color: #ff8c00;
            height: 30px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(255, 140, 0, 0.5);
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <span>Juicer: <strong style="color:#fff;"><%= user.username %></strong></span>
        <span><span class="balance-text">Balance: </span><span class="balance-amount" id="balance-display"><%= user.balance.toFixed(2) %></span> €</span>
    </div>

    <div class="slot-machine">
        <div class="grid" id="slot-grid"></div>
    </div>

    <div class="controls">
        <div id="msg-board">READY TO GRIND</div>
        <button class="spin-btn" id="spin-btn">SPIN (1€)</button>
    </div>

    <script>
        console.log("Slot Engine geladen! Warte auf Spin...");

        const gridElement = document.getElementById('slot-grid');
        const spinBtn = document.getElementById('spin-btn');
        const msgBoard = document.getElementById('msg-board');
        const balanceDisplay = document.getElementById('balance-display');
        
        let isSpinning = false;
        const cols = 5;
        const rows = 5;

        // Init Grid
        function initGrid() {
            gridElement.innerHTML = '';
            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    let cell = document.createElement('div');
                    cell.className = 'cell';
                    cell.id = `cell-${r}-${c}`;
                    cell.innerText = '🍊'; 
                    gridElement.appendChild(cell);
                }
            }
        }
        initGrid();

        // Event Listener anstatt "onclick" (Macht den CSP glücklich)
        spinBtn.addEventListener('click', async function startSpin() {
            console.log("Spin-Button wurde geklickt!");
            if (isSpinning) return;
            isSpinning = true;
            spinBtn.disabled = true;
            msgBoard.innerText = "SPINNING...";
            msgBoard.style.color = "#fff";

            // Optik: Alles dreht sich
            document.querySelectorAll('.cell').forEach(cell => {
                cell.classList.remove('juicer-active');
                cell.classList.add('spinning');
                cell.innerText = '🌀'; 
            });

            try {
                console.log("Sende Anfrage an Server...");
                const response = await fetch('/api/spin', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const result = await response.json();
                console.log("Antwort vom Server:", result);

                if (result.error) {
                    msgBoard.innerText = result.error;
                    msgBoard.style.color = "#ff0000";
                    isSpinning = false;
                    spinBtn.disabled = false;
                    return;
                }

                // Balance updaten
                balanceDisplay.innerText = result.newBalance.toFixed(2);

                // Walzen stoppen (von links nach rechts)
                for (let col = 0; col < cols; col++) {
                    await new Promise(r => setTimeout(r, 200)); 
                    for (let row = 0; row < rows; row++) {
                        let cell = document.getElementById(`cell-${row}-${col}`);
                        cell.classList.remove('spinning');
                        cell.innerText = result.grid[row][col].icon; 
                    }
                }

                await handleWinAnimations(result);

            } catch (err) {
                console.error("KRITISCHER FEHLER:", err);
                msgBoard.innerText = "SERVER ERROR!";
                isSpinning = false;
                spinBtn.disabled = false;
            }
        });

        async function handleWinAnimations(result) {
            if (result.scatters >= 3) {
                msgBoard.innerText = "🚨 FREISPIELE GETRIGGERT! 🚨";
                msgBoard.style.color = "#ff0000";
            }

            if (result.juicerDuels && result.juicerDuels.length > 0) {
                for (let duel of result.juicerDuels) {
                    for (let r = 0; r < rows; r++) {
                        let cell = document.getElementById(`cell-${r}-${duel.col}`);
                        cell.classList.add('juicer-active');
                        cell.innerText = '🌪️';
                    }
                    msgBoard.innerText = `VS DUEL...`;
                    await new Promise(r => setTimeout(r, 800)); 
                    msgBoard.innerText = `🔥 ${duel.multi}x JUICER! 🔥`;
                    await new Promise(r => setTimeout(r, 800));
                }
            }

            if (result.win > 0) {
                msgBoard.innerText = `BIG WIN: ${result.win.toFixed(2)} €!`;
                msgBoard.style.color = "#0f0";
            } else {
                if (result.scatters < 3) msgBoard.innerText = "DEAD SPIN.";
            }

            isSpinning = false;
            spinBtn.disabled = false;
        }
    </script>
</body>
</html>
