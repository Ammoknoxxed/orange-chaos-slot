<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chaos Orange | Duel Edition</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser-arcade-physics.min.js"></script>
    <style>
        body {
            background-color: #030303;
            color: #fff;
            font-family: Impact, 'Arial Black', sans-serif; 
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            background: radial-gradient(circle at center, #1a0a00 0%, #000 100%);
        }

        #game-wrapper {
            position: relative;
            width: 1000px;
            height: 800px;
            background: #080808;
            border-radius: 10px;
            box-shadow: 0 0 50px rgba(0,0,0,0.9);
            border: 2px solid #1a1a1a;
        }

        #control-bar {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 80px;
            background: #050505;
            border-top: 2px solid #222;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 30px;
            box-sizing: border-box;
            z-index: 100;
        }

        .panel-box { display: flex; flex-direction: column; justify-content: center; }
        .panel-label { color: #555; font-size: 14px; line-height: 1; letter-spacing: 1px; font-family: Arial, sans-serif; font-weight: bold;}
        .panel-value { color: #fff; font-size: 26px; line-height: 1.2; letter-spacing: 1px; }
        .win-value { color: #ff8c00; font-size: 34px; text-shadow: 0 0 10px rgba(255, 140, 0, 0.4); }

        #bullet-counter {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0,0,0,0.8);
            border: 2px solid #00ccff;
            padding: 10px;
            border-radius: 5px;
            color: #00ccff;
            font-size: 20px;
            z-index: 100;
            display: none;
        }

        #spin-btn {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: transparent;
            border: 3px solid #ff8c00;
            color: #ff8c00;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.2s;
        }
        #spin-btn::before { content: "↻"; font-size: 36px; font-family: Arial; }
        #spin-btn:hover { background: rgba(255, 140, 0, 0.1); transform: scale(1.05); }
        #spin-btn:active { transform: scale(0.95); }
        #spin-btn:disabled { border-color: #333; color: #333; cursor: not-allowed; }

        #msg-overlay {
            position: absolute;
            top: 40%;
            width: 100%;
            text-align: center;
            font-size: 80px;
            color: #fff;
            text-shadow: 0 10px 40px rgba(0,0,0,0.9);
            pointer-events: none;
            opacity: 0;
            z-index: 200;
            transform: scale(0.5);
            transition: all 0.3s;
            letter-spacing: 2px;
        }
    </style>
</head>
<body>

    <div id="game-wrapper">
        <div id="phaser-canvas"></div>
        <div id="msg-overlay">WILD WILD WEST</div>
        <div id="bullet-counter">BULLETS: 0/6</div>

        <div id="control-bar">
            <div class="panel-box">
                <span class="panel-label">BALANCE</span>
                <span class="panel-value"><span id="ui-balance"><%= user.balance.toFixed(2) %></span> €</span>
            </div>
            
            <div class="panel-box" style="text-align: center;">
                <span class="panel-label" id="ui-win-label">WIN</span>
                <span class="panel-value win-value" id="ui-win">0.00 €</span>
            </div>

            <div class="panel-box" style="align-items: center; flex-direction: row; gap: 20px;">
                <button id="spin-btn"></button>
            </div>
        </div>
    </div>

    <script>
        const uiBalance = document.getElementById('ui-balance');
        const uiWin = document.getElementById('ui-win');
        const uiWinLabel = document.getElementById('ui-win-label');
        const spinBtn = document.getElementById('spin-btn');
        const msgOverlay = document.getElementById('msg-overlay');
        const bulletCounter = document.getElementById('bullet-counter');

        const REEL_COUNT = 5; const ROW_COUNT = 5;
        const SYMBOL_W = 140; const SYMBOL_H = 120; 
        const REEL_OFFSET_X = 150; const REEL_OFFSET_Y = 60;  

        const symbolStyles = {
            'ORANGE':  { text: 'ORG', color: '#ff6600' },
            'ROLEX':   { text: 'RLX', color: '#ffcc00' },
            'BÜNDEL':  { text: 'CASH', color: '#00ff44' },
            'ENERGY':  { text: 'NRG', color: '#0088ff' },
            'CAP':     { text: 'CAP', color: '#888888' },
            'ACE':     { text: 'A', color: '#aaaaaa' },
            'KING':    { text: 'K', color: '#aaaaaa' },
            'QUEEN':   { text: 'Q', color: '#aaaaaa' },
            'JACK':    { text: 'J', color: '#aaaaaa' },
            'TEN':     { text: '10', color: '#aaaaaa' },
            'WILD':    { text: 'WILD', color: '#ff00ff' }, 
            'JUICER':  { text: 'VS', color: '#888888' }, // Toter VS
            'OUTLAW':  { text: 'GUN', color: '#00ccff' }, 
            'SCATTER': { text: 'FS', color: '#ffdd00' } 
        };
        const symbolKeys = Object.keys(symbolStyles).filter(k=>k!=='WILD');

        let isAutoPlay = false;

        class GameScene extends Phaser.Scene {
            constructor() { super('GameScene'); }

            create() {
                this.bonusBg = this.add.rectangle(500, 400, 1000, 800, 0xff0000).setAlpha(0);

                for (let col = 0; col < REEL_COUNT; col++) {
                    this.add.rectangle(REEL_OFFSET_X + col * SYMBOL_W + (SYMBOL_W/2), REEL_OFFSET_Y + (SYMBOL_H * ROW_COUNT)/2, SYMBOL_W - 8, SYMBOL_H * ROW_COUNT, 0x0a0a0a).setOrigin(0.5);
                }

                this.reelsContainer = this.add.container(REEL_OFFSET_X, REEL_OFFSET_Y);
                this.reels = [];

                const globalMask = this.add.graphics().fillRect(REEL_OFFSET_X, REEL_OFFSET_Y, SYMBOL_W * REEL_COUNT, SYMBOL_H * ROW_COUNT).createGeometryMask();
                this.reelsContainer.setMask(globalMask);

                for (let col = 0; col < REEL_COUNT; col++) {
                    const reelData = { container: this.add.container(col * SYMBOL_W, 0), symbols: [], isSpinning: false, vsOverlay: null };
                    this.reelsContainer.add(reelData.container);
                    
                    for (let r = -1; r < ROW_COUNT + 1; r++) {
                        let symTxt = this.add.text(SYMBOL_W / 2, r * SYMBOL_H + (SYMBOL_H / 2), 'A', { fontFamily: 'Impact, sans-serif', fontSize: '50px', color: '#ffffff' }).setOrigin(0.5);
                        reelData.container.add(symTxt);
                        reelData.symbols.push({ textObj: symTxt, yPos: r });
                    }

                    let vsBanner = this.add.container(col * SYMBOL_W, 0).setAlpha(0);
                    let vsBg = this.add.rectangle(SYMBOL_W/2, (SYMBOL_H * ROW_COUNT)/2, SYMBOL_W - 4, SYMBOL_H * ROW_COUNT, 0xaa0000).setOrigin(0.5);
                    let vsText = this.add.text(SYMBOL_W/2, (SYMBOL_H * ROW_COUNT)/2, '100x', { fontFamily: 'Impact', fontSize: '65px', color: '#ffffff' }).setOrigin(0.5);
                    vsBanner.add([vsBg, vsText]);
                    this.reelsContainer.add(vsBanner);
                    reelData.vsOverlay = { container: vsBanner, text: vsText, bg: vsBg };

                    this.reels.push(reelData);
                }

                this.reels.forEach(reel => reel.symbols.forEach(s => this.setSymbolVisual(s, Phaser.Utils.Array.GetRandom(symbolKeys))));
                spinBtn.addEventListener('click', () => this.startSpin());
            }

            setSymbolVisual(symbolObj, symName) {
                const cleanName = symName.replace('WILD_OUTLAW', 'WILD').replace('WILD_VS', 'WILD').replace('WILD_TEST', 'JUICER');
                const style = symbolStyles[cleanName] || symbolStyles['ORANGE'];
                symbolObj.textObj.setText(style.text);
                symbolObj.textObj.setColor(style.color);
            }

            update() {
                this.reels.forEach(reel => {
                    if (reel.isSpinning) {
                        reel.symbols.forEach(s => {
                            s.textObj.y += 45; 
                            if (s.textObj.y > (ROW_COUNT) * SYMBOL_H + (SYMBOL_H/2)) {
                                s.textObj.y -= (ROW_COUNT + 2) * SYMBOL_H;
                                this.setSymbolVisual(s, Phaser.Utils.Array.GetRandom(symbolKeys));
                                s.textObj.setAlpha(0.3); 
                            }
                        });
                    }
                });
            }

            showOverlayMsg(text, color) {
                msgOverlay.innerText = text; msgOverlay.style.color = color; msgOverlay.style.opacity = 1; msgOverlay.style.transform = "scale(1)";
                setTimeout(() => { msgOverlay.style.opacity = 0; msgOverlay.style.transform = "scale(0.5)"; }, 2500);
            }

            async startSpin() {
                spinBtn.disabled = true;
                if(!isAutoPlay) { uiWin.innerText = "0.00 €"; this.tweens.add({ targets: this.bonusBg, alpha: 0, duration: 300 }); bulletCounter.style.display = 'none'; }

                this.reels.forEach(reel => { reel.isSpinning = true; reel.vsOverlay.container.setAlpha(0); });

                try {
                    const response = await fetch('/api/spin', { method: 'POST', headers: { 'Content-Type': 'application/json' }});
                    const result = await response.json();

                    if (result.error) { spinBtn.disabled = false; return; }
                    uiBalance.innerText = result.newBalance.toFixed(2);

                    // Update Bullet Counter
                    if(result.bullets !== undefined && result.bullets > 0) {
                        bulletCounter.style.display = 'block';
                        bulletCounter.innerText = `BULLETS: ${result.bullets}/6`;
                    }

                    for (let c = 0; c < REEL_COUNT; c++) {
                        await new Promise(res => setTimeout(res, 200)); 
                        this.stopReel(c, result.grid);
                    }

                    await this.handleWinAnimations(result);

                } catch (err) { console.error(err); spinBtn.disabled = false; }
            }

            stopReel(colIdx, gridData) {
                const reel = this.reels[colIdx];
                reel.isSpinning = false; 
                reel.symbols.sort((a,b) => a.textObj.y - b.textObj.y);
                
                for(let i = 0; i < reel.symbols.length; i++) {
                    const s = reel.symbols[i];
                    const r = i - 1; 
                    if (r >= 0 && r < ROW_COUNT) this.setSymbolVisual(s, gridData[r][colIdx]);
                    else this.setSymbolVisual(s, Phaser.Utils.Array.GetRandom(symbolKeys));
                    s.textObj.setAlpha(1);
                    
                    let targetY = r * SYMBOL_H + (SYMBOL_H/2);
                    s.textObj.y = targetY - 60;
                    this.tweens.add({ targets: s.textObj, y: targetY, duration: 350, ease: 'Back.easeOut' });
                }
            }

            async handleWinAnimations(result) {
                if (result.outlaws && result.outlaws.length > 0) {
                    for (let outlaw of result.outlaws) {
                        const vsBanner = this.reels[outlaw.col].vsOverlay;
                        vsBanner.bg.setFillStyle(0x0055ff); 
                        vsBanner.text.setText(`GUN\n${outlaw.multi}x`);
                        this.tweens.add({ targets: vsBanner.container, alpha: 1, duration: 250 });
                        this.cameras.main.shake(300, 0.005);
                        
                        msgOverlay.innerText = `BANG! ${outlaw.bullets} WILDS`;
                        msgOverlay.style.color = "#00ccff";
                        msgOverlay.style.opacity = 1;
                        await new Promise(res => setTimeout(res, 1200)); 
                        msgOverlay.style.opacity = 0;
                    }
                    result.shotsFired.forEach(spot => {
                        let reel = this.reels[spot.c];
                        let sym = reel.symbols.find(s => s.textObj.y > spot.r*SYMBOL_H && s.textObj.y < (spot.r+1)*SYMBOL_H);
                        if(sym) { this.setSymbolVisual(sym, 'WILD'); this.tweens.add({targets:sym.textObj, scale:1.3, yoyo:true, duration:200}); }
                    });
                }

                if (result.vsJuicers && result.vsJuicers.length > 0) {
                    for (let vs of result.vsJuicers) {
                        const vsBanner = this.reels[vs.col].vsOverlay;
                        vsBanner.bg.setFillStyle(0xaa0000); 
                        vsBanner.text.setText(`VS\n${vs.multi}x`);
                        this.tweens.add({ targets: vsBanner.container, alpha: 1, duration: 250 });
                        this.cameras.main.shake(300, 0.005);
                        await new Promise(res => setTimeout(res, 1000)); 
                    }
                }

                if (result.bonusTriggered === 'WILD_WEST') {
                    this.showOverlayMsg("WILD WILD WEST", "#ff0000");
                    this.bonusBg.setFillStyle(0xff0000);
                    this.tweens.add({ targets: this.bonusBg, alpha: 0.3, yoyo: true, repeat: -1, duration: 800 });
                    await new Promise(res => setTimeout(res, 2500));
                } else if (result.bonusTriggered === 'DUSK_DAWN') {
                    this.showOverlayMsg("DUSK 'TIL DAWN", "#0088ff");
                    this.bonusBg.setFillStyle(0x002255);
                    this.tweens.add({ targets: this.bonusBg, alpha: 0.5, yoyo: true, repeat: -1, duration: 800 });
                    bulletCounter.style.display = 'block';
                    await new Promise(res => setTimeout(res, 2500));
                }

                if (result.win > 0) {
                    uiWin.innerText = `${result.win.toFixed(2)} €`;
                    this.tweens.add({ targets: uiWin, scaleX: 1.1, scaleY: 1.1, yoyo: true, duration: 150 });
                    await new Promise(res => setTimeout(res, 1000));
                }

                if (result.nextAction === 'DUEL_SPIN') {
                    this.showOverlayMsg("DUEL SPIN!", "#ff0044");
                    uiWinLabel.innerText = "DUEL SPIN";
                    isAutoPlay = true;
                    await new Promise(res => setTimeout(res, 1500));
                    this.startSpin();
                } else if (result.spinsLeft > 0) {
                    uiWinLabel.innerText = `FREE SPINS: ${result.spinsLeft}`;
                    isAutoPlay = true;
                    await new Promise(res => setTimeout(res, 800));
                    this.startSpin();
                } else if (result.nextAction === 'END_BONUS') {
                    this.showOverlayMsg(`TOTAL WIN\n${result.totalBonusWin.toFixed(2)} €`, "#00ff44");
                    this.tweens.add({ targets: this.bonusBg, alpha: 0, duration: 1000 }); 
                    uiWinLabel.innerText = "WIN";
                    bulletCounter.style.display = 'none';
                    isAutoPlay = false;
                    await new Promise(res => setTimeout(res, 3000));
                    spinBtn.disabled = false;
                } else {
                    spinBtn.disabled = false;
                }
            }
        }

        const config = { type: Phaser.CANVAS, width: 1000, height: 720, parent: 'phaser-canvas', transparent: true, scene: [GameScene] };
        const game = new Phaser.Game(config);
    </script>
</body>
</html>
