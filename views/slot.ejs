<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CHAOS ORANGE | Cascades</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Inter:wght@400;700;900&display=swap');

        :root {
            --bg-dark: #050a0f;
            --panel-bg: #0b131a;
            --accent-main: #ff5500;
            --toxic-green: #00e701;
            --text-main: #8a9ba8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg-dark);
            font-family: 'Inter', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
            background: radial-gradient(circle at center, #1a0800 0%, #000 100%);
        }

        #game-wrapper {
            position: relative;
            width: 1000px;
            height: 850px;
            background: #000;
            border-radius: 20px;
            box-shadow: 0 0 50px rgba(255, 85, 0, 0.1), 0 0 0 2px rgba(255, 255, 255, 0.05);
            overflow: hidden;
        }

        #phaser-canvas { width: 100%; height: 750px; }

        #top-hud {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            display: flex;
            justify-content: space-between;
            z-index: 100;
            pointer-events: none;
        }

        .hud-box {
            background: rgba(0, 0, 0, 0.8);
            border: 2px solid rgba(255, 255, 255, 0.1);
            padding: 10px 20px;
            border-radius: 12px;
            backdrop-filter: blur(5px);
            text-align: center;
            display: none;
            transform: scale(0.9);
            transition: 0.3s;
        }

        .hud-box.active { display: block; transform: scale(1); }
        .hud-label { color: var(--text-main); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; font-weight: bold; }
        .hud-value { font-family: 'Black Ops One', Impact; font-size: 28px; color: var(--toxic-green); }
        .hud-multi { color: var(--accent-main); }

        #control-bar {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 100px;
            background: var(--panel-bg);
            border-top: 2px solid rgba(255, 255, 255, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
            box-sizing: border-box;
            z-index: 100;
        }

        .panel-box {
            background: rgba(0, 0, 0, 0.3);
            padding: 10px 20px;
            border-radius: 8px;
            min-width: 140px;
            border: 1px solid rgba(255, 255, 255, 0.02);
            display: flex;
            flex-direction: column;
        }

        .panel-label { color: var(--text-main); font-size: 11px; text-transform: uppercase; font-weight: 900; letter-spacing: 1px; }
        .panel-value { color: #fff; font-size: 22px; font-weight: 900; }

        .win-box {
            background: rgba(0, 231, 1, 0.05);
            border: 1px solid rgba(0, 231, 1, 0.2);
            text-align: center;
            min-width: 200px;
            transition: transform 0.2s;
        }

        .win-value { color: var(--toxic-green); font-size: 30px; text-shadow: 0 0 15px rgba(0, 231, 1, 0.4); }

        .btn-buy {
            background: transparent;
            border: 2px solid var(--accent-main);
            color: var(--accent-main);
            font-weight: 900;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
            text-transform: uppercase;
            font-size: 14px;
        }

        .btn-buy:hover { background: var(--accent-main); color: #000; box-shadow: 0 0 15px var(--accent-main); }
        .btn-buy:disabled { opacity: 0.5; cursor: not-allowed; }

        #spin-btn {
            width: 75px;
            height: 75px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--toxic-green), #00b300);
            border: none;
            color: #000;
            font-size: 26px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 0 20px rgba(0, 231, 1, 0.4);
            transition: 0.1s;
            outline: none;
        }

        #spin-btn:hover { transform: scale(1.1); box-shadow: 0 0 30px rgba(0, 231, 1, 0.6); }
        #spin-btn:active { transform: scale(0.9); }
        #spin-btn:disabled {
            background: #222; color: #555; box-shadow: none; transform: scale(1); cursor: not-allowed; border: 2px solid #333;
        }

        #msg-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 750px;
            display: flex; justify-content: center; align-items: center;
            background: rgba(0, 0, 0, 0.8);
            z-index: 200; opacity: 0; pointer-events: none; transition: 0.3s;
        }

        #msg-overlay.active { opacity: 1; pointer-events: all; }

        .msg-text {
            font-family: 'Black Ops One', Impact;
            font-size: 80px;
            color: var(--accent-main);
            text-transform: uppercase;
            text-shadow: 0 10px 40px #ff0000;
            transform: scale(0.5);
            transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-align: center;
        }

        #msg-overlay.active .msg-text { transform: scale(1); }

        .bet-input {
            width: 60px; padding: 5px; background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1); color: #fff;
            border-radius: 4px; text-align: center; font-weight: bold;
        }

        .stats-link, .logout-btn {
            position: absolute; top: 20px; font-size: 14px; z-index: 100; transition: 0.3s; text-decoration: none;
        }
        .stats-link { right: 20px; color: var(--accent-main); }
        .stats-link:hover { color: var(--toxic-green); }
        
        .logout-btn {
            right: 100px; background: rgba(255, 85, 0, 0.2); border: 1px solid var(--accent-main);
            color: var(--accent-main); padding: 6px 14px; border-radius: 6px; font-size: 12px;
        }
        .logout-btn:hover { background: var(--accent-main); color: #000; }

        .mod-link {
            position: absolute; top: 20px; right: 180px; font-size: 14px; z-index: 100;
            text-decoration: none; background: rgba(255, 85, 0, 0.2); border: 1px solid var(--accent-main);
            color: #ffcc00; padding: 6px 14px; border-radius: 6px; font-weight: bold;
        }
        .mod-link:hover { background: var(--accent-main); color: #000; }
    </style>
</head>
<body>
    <div id="game-wrapper">
        <% if (role === 'mod') { %>
            <a href="/mod" class="mod-link"><i class="fas fa-shield-alt"></i> Mod Panel</a>
        <% } %>

        <a href="/api/stats" class="stats-link" target="_blank"><i class="fas fa-chart-bar"></i> Stats</a>
        <a href="/logout" class="logout-btn">Logout</a>

        <div id="top-hud">
            <div class="hud-box" id="fs-hud">
                <div class="hud-label">Free Spins</div>
                <div class="hud-value" id="fs-count">0</div>
            </div>
            <div class="hud-box" id="multi-hud">
                <div class="hud-label">Global Multi</div>
                <div class="hud-value hud-multi" id="global-multi">x0</div>
            </div>
        </div>

        <div id="phaser-canvas"></div>

        <div id="msg-overlay">
            <div class="msg-text" id="main-msg">CHAOS!</div>
        </div>

        <div id="control-bar">
            <div class="panel-box">
                <span class="panel-label">Balance</span>
                <span class="panel-value"><span id="ui-balance"><%= user.balance.toFixed(2) %></span>€</span>
            </div>

            <div class="panel-box win-box" id="win-box-container">
                <span class="panel-label">Cascade Win</span>
                <span class="panel-value win-value" id="ui-win">0.00€</span>
            </div>

            <div style="display: flex; gap: 20px; align-items: center;">
                <button class="btn-buy" id="buy-btn"><i class="fas fa-shopping-cart"></i> Buy Feature</button>
                <div class="panel-box" style="text-align: center; min-width: 90px; padding: 5px 10px;">
                    <span class="panel-label" style="margin-bottom: 3px;">Bet</span>
                    <input type="number" id="bet-input" class="bet-input" min="0.1" max="100" step="0.1" value="1">
                </div>
                <button id="spin-btn"><i class="fas fa-redo-alt"></i></button>
            </div>
        </div>
    </div>

    <script>
        const uiBalance = document.getElementById('ui-balance');
        const uiWin = document.getElementById('ui-win');
        const winBoxContainer = document.getElementById('win-box-container');
        const spinBtn = document.getElementById('spin-btn');
        const buyBtn = document.getElementById('buy-btn');
        const msgOverlay = document.getElementById('msg-overlay');
        const mainMsg = document.getElementById('main-msg');
        const fsHud = document.getElementById('fs-hud');
        const fsCount = document.getElementById('fs-count');
        const multiHud = document.getElementById('multi-hud');
        const globalMulti = document.getElementById('global-multi');
        const betInput = document.getElementById('bet-input');

        const COLS = 6;
        const ROWS = 5;
        const SYMBOL_W = 120;
        const SYMBOL_H = 120;
        const OFFSET_X = 140;
        const OFFSET_Y = 85;

        const fxColors = {
            'BOMB': 0xff0044,
            'SCATTER': 0xffcc00
        };

        class GameScene extends Phaser.Scene {
            constructor() { super('GameScene'); }

            preload() {
                this.load.image('ORANGE', '/images/symbols/orange.png');
                this.load.image('ROLEX', '/images/symbols/rolex.png');
                this.load.image('CASH', '/images/symbols/cash.png');
                this.load.image('ENERGY', '/images/symbols/energy.png');
                this.load.image('A', '/images/symbols/ace.png');
                this.load.image('K', '/images/symbols/king.png');
                this.load.image('Q', '/images/symbols/queen.png');
                this.load.image('J', '/images/symbols/jack.png');
                this.load.image('TEN', '/images/symbols/10.png');
                this.load.image('BOMB', '/images/symbols/bomb.png');
                this.load.image('SCATTER', '/images/symbols/scatter.png');
            }

            create() {
                for (let c = 0; c < COLS; c++) {
                    for (let r = 0; r < ROWS; r++) {
                        this.add.rectangle(OFFSET_X + c * SYMBOL_W, OFFSET_Y + r * SYMBOL_H, SYMBOL_W - 8, SYMBOL_H - 8, 0x0f151c)
                            .setOrigin(0.5).setStrokeStyle(1, 0x1a2430);
                    }
                }

                const mask = this.make.graphics();
                mask.fillStyle(0xffffff);
                mask.fillRect(OFFSET_X - SYMBOL_W / 2, OFFSET_Y - SYMBOL_H / 2 - 20, SYMBOL_W * COLS, SYMBOL_H * ROWS + 40);
                
                this.gridContainer = this.add.container(OFFSET_X, OFFSET_Y);
                this.gridContainer.setMask(mask.createGeometryMask());

                this.displayGrid = Array(COLS).fill(null).map(() => Array(ROWS).fill(null));

                this.spawnInitialGrid(Array(COLS).fill(Array(ROWS).fill({name: 'ORANGE'})));

                spinBtn.addEventListener('click', () => this.doRequest(false));
                buyBtn.addEventListener('click', () => this.doRequest(true));
            }

            createSymbol(c, r, name, multi = null) {
                let container = this.add.container(c * SYMBOL_W, r * SYMBOL_H);

                let bg = this.add.graphics();
                bg.fillStyle(0x0a0f14, 0.9);
                bg.fillRoundedRect(-SYMBOL_W/2 + 5, -SYMBOL_H/2 + 5, SYMBOL_W - 10, SYMBOL_H - 10, 16);
                bg.lineStyle(1, 0x223040, 0.8);
                bg.strokeRoundedRect(-SYMBOL_W/2 + 5, -SYMBOL_H/2 + 5, SYMBOL_W - 10, SYMBOL_H - 10, 16);
                container.add(bg);

                if (this.textures.exists(name)) {
                    let img = this.add.image(0, 0, name);
                    img.setDisplaySize(SYMBOL_W - 35, SYMBOL_H - 35); 
                    container.add(img);
                } else {
                    let txt = this.add.text(0, 0, name, { fontFamily: 'Inter', fontSize: '16px', color: '#ff0000', fontStyle: 'bold' }).setOrigin(0.5);
                    container.add(txt);
                }

                if (name === 'BOMB' && multi) {
                    let badgeBg = this.add.graphics();
                    badgeBg.fillStyle(0x000000, 0.9);
                    badgeBg.fillRoundedRect(-30, 20, 60, 25, 6);
                    badgeBg.lineStyle(2, fxColors.BOMB, 1);
                    badgeBg.strokeRoundedRect(-30, 20, 60, 25, 6);
                    container.add(badgeBg);

                    let multiTxt = this.add.text(0, 32, `${multi}x`, {
                        fontFamily: 'Black Ops One',
                        fontSize: '18px',
                        color: '#fff'
                    }).setOrigin(0.5);
                    container.add(multiTxt);

                    let glow = this.add.circle(0, 0, 40, fxColors.BOMB, 0.4).setBlendMode(Phaser.BlendModes.ADD);
                    this.tweens.add({ targets: glow, scale: 1.2, alpha: 0.1, yoyo: true, repeat: -1, duration: 600 });
                    container.addAt(glow, 0); 
                }

                if (name === 'SCATTER') {
                    let glow = this.add.circle(0, 0, 45, fxColors.SCATTER, 0.5).setBlendMode(Phaser.BlendModes.ADD);
                    this.tweens.add({ targets: glow, scale: 1.4, alpha: 0, yoyo: false, repeat: -1, duration: 1000 });
                    container.addAt(glow, 0);
                }

                container.setScale(0);
                this.tweens.add({ targets: container, scale: 1, duration: 300, ease: 'Back.out' });

                this.gridContainer.add(container);
                return { obj: container, name: name, multi: multi };
            }

            showMsg(text, color, shake = true) {
                mainMsg.innerText = text;
                mainMsg.style.color = color;
                mainMsg.style.textShadow = `0 10px 50px ${color}, 0 0 15px #fff`;
                msgOverlay.classList.add('active');
                if (shake) this.cameras.main.shake(500, 0.02);
                setTimeout(() => { msgOverlay.classList.remove('active'); }, 2000);
            }

            async doRequest(isBuy) {
                spinBtn.disabled = true; buyBtn.disabled = true;
                uiWin.innerText = '0.00€'; uiWin.style.color = 'var(--toxic-green)';

                try {
                    const betAmount = parseFloat(betInput.value) || 1;
                    const res = await fetch('/api/spin', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ buyFeature: isBuy, bet: betAmount })
                    });
                    const data = await res.json();

                    if (data.error) {
                        this.showMsg(data.error, '#ff0000');
                        spinBtn.disabled = false; buyBtn.disabled = false; return;
                    }

                    uiBalance.innerText = data.newBalance.toFixed(2);
                    await this.playCascades(data);
                } catch (e) {
                    console.error(e); spinBtn.disabled = false; buyBtn.disabled = false;
                }
            }

            async playCascades(data) {
                let rollingWin = 0;

                for (let i = 0; i < data.cascades.length; i++) {
                    let step = data.cascades[i];
                    if (i === 0) {
                        await this.spawnInitialGrid(step.grid);
                        await new Promise(res => setTimeout(res, 400));
                    } else {
                        await this.applyGravityVisuals(step.grid);
                        await new Promise(res => setTimeout(res, 400));
                    }

                    if (step.wins.length > 0) {
                        await this.explodeSymbols(step.removed);
                        rollingWin += step.stepWin;
                        uiWin.innerText = `${rollingWin.toFixed(2)}€`;
                        winBoxContainer.style.transform = 'scale(1.1)';
                        setTimeout(() => winBoxContainer.style.transform = 'scale(1)', 150);
                    }
                }

                if (data.totalBaseWin > 0 && data.bombs.length > 0) {
                    await new Promise(res => setTimeout(res, 400));
                    await this.showBombMultipliers(data.bombs);
                }

                if (data.bonusTriggered) {
                    this.showMsg('FREE SPINS!', '#ffcc00');
                    fsHud.classList.add('active'); fsCount.innerText = data.spinsLeft;
                } else if (data.spinsLeft > 0) {
                    fsHud.classList.add('active'); fsCount.innerText = data.spinsLeft;
                } else {
                    fsHud.classList.remove('active');
                }

                if (data.globalMultiplier > 0) {
                    multiHud.classList.add('active'); globalMulti.innerText = `x${data.globalMultiplier}`;
                }

                if (data.finalSpinWin > 0) {
                    uiWin.innerText = `${data.finalSpinWin.toFixed(2)}€`;
                    uiWin.style.color = data.finalSpinWin >= 100 ? '#ffcc00' : 'var(--toxic-green)';
                }

                spinBtn.disabled = false; buyBtn.disabled = false;
            }

            async spawnInitialGrid(grid) {
                for (let c = 0; c < COLS; c++) {
                    for (let r = 0; r < ROWS; r++) {
                        if (this.displayGrid[c][r] && this.displayGrid[c][r].obj) {
                            this.displayGrid[c][r].obj.destroy(); 
                        }
                        let sym = grid[c][r];
                        this.displayGrid[c][r] = this.createSymbol(c, r, sym.name, sym.multi);
                    }
                }
            }

            async applyGravityVisuals(grid) {
                for (let c = 0; c < COLS; c++) {
                    for (let r = 0; r < ROWS; r++) {
                        if (this.displayGrid[c][r] && this.displayGrid[c][r].obj) {
                            this.displayGrid[c][r].obj.destroy(); 
                        }
                        let sym = grid[c][r];
                        this.displayGrid[c][r] = this.createSymbol(c, r, sym.name, sym.multi);
                    }
                }
            }

            async explodeSymbols(positions) {
                for (let pos of positions) {
                    let sym = this.displayGrid[pos.c][pos.r];
                    if (sym && sym.obj) {
                        this.tweens.add({
                            targets: sym.obj,
                            scale: 0,
                            alpha: 0,
                            duration: 300,
                            ease: 'Power2.out',
                            onComplete: () => { if(sym.obj) sym.obj.destroy(); }
                        });
                        this.displayGrid[pos.c][pos.r] = null;
                    }
                }
                await new Promise(res => setTimeout(res, 300));
            }

            async showBombMultipliers(bombs) {
                for (let bomb of bombs) {
                    let sym = this.displayGrid[bomb.c][bomb.r];
                    if (sym && sym.obj) {
                        this.tweens.add({
                            targets: sym.obj, scale: 1.3, duration: 200, yoyo: true, repeat: 2
                        });
                    }
                }
            }
        }

        const config = {
            type: Phaser.AUTO,
            parent: 'phaser-canvas',
            width: 1000,
            height: 750,
            backgroundColor: '#000000',
            scene: GameScene
        };

        const game = new Phaser.Game(config);
    </script>
</body>
</html>
